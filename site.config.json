{
  "site": {
    "title": "plain — sample site",
    "url": "https://victorantos.github.io/kiln",
    "basePath": "/kiln",
    "description": "The sample site that ships with plain, the Git-native CMS. Served from GitHub project Pages under /kiln/.",
    "language": "en",
    "theme": "toolbox"
  },
  "collections": {
    "pages": {
      "path": "content/pages",
      "urlPattern": "/:slug/",
      "template": "page",
      "fields": [
        {
          "name": "title",
          "type": "text",
          "required": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    },
    "posts": {
      "path": "content/posts",
      "urlPattern": "/blog/:slug/",
      "template": "post",
      "listUrl": "/blog/",
      "listTemplate": "list",
      "label": "Blog",
      "sortBy": "date",
      "sortOrder": "desc",
      "rss": true,
      "fields": [
        {
          "name": "title",
          "type": "text",
          "required": true
        },
        {
          "name": "date",
          "type": "date",
          "required": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "cover",
          "type": "image"
        },
        {
          "name": "tags",
          "type": "list"
        },
        {
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    },
    "menu": {
      "path": "content/menu",
      "urlPattern": "/menu/:slug/",
      "template": "menu-item",
      "listUrl": "/menu/",
      "listTemplate": "menu",
      "label": "Menu",
      "sortBy": "section",
      "sortOrder": "asc",
      "pageSize": 100,
      "fields": [
        {
          "name": "title",
          "type": "text",
          "required": true
        },
        {
          "name": "price",
          "type": "text"
        },
        {
          "name": "section",
          "type": "select",
          "options": [
            "Starters",
            "Mains",
            "Desserts",
            "Drinks"
          ]
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    },
    "services": {
      "path": "content/services",
      "urlPattern": "/services/:slug/",
      "template": "service",
      "listUrl": "/services/",
      "listTemplate": "list",
      "label": "Services",
      "sortBy": "title",
      "sortOrder": "asc",
      "fields": [
        {
          "name": "title",
          "type": "text",
          "required": true
        },
        {
          "name": "description",
          "type": "text"
        },
        {
          "name": "priceFrom",
          "type": "text"
        },
        {
          "name": "included",
          "type": "list"
        },
        {
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    }
  },
  "plugins": [
    "search",
    "reading-time"
  ]
}
